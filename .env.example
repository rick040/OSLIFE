#   SYNC_SECRET           JS8V924Skxul3api9JYpiMc4e6IH7YQc2GbcEIa_pkU
#   WALLET_WEBHOOK_SECRET gCJtlIvi1pQXdejIhwaErgp1lVjrbLb5jPJ872rAmDs
#   INGEST_SECRET         DnUy-KnKCvxczxWThNlwlIGeTIrLKbokuFAtVCoq9FU
# (SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected, don't add them)
