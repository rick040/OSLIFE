# RICK-OS · frontend env (Vite). Copy to .env.local and fill in.
# ONLY public values here. Never put the service_role key or any API secret in the app.

VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon public key>

# Toggle: 'mock' uses seeded local data (default), 'supabase' uses the live backend.
VITE_DATA_SOURCE=mock
