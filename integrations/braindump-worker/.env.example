# OSLIFE braindump media worker — environment
# Set these in your host's dashboard (Fly.io / Railway / Render) — never commit real values.

PORT=8080

# Shared secret. Must match the WORKER_SECRET set on the braindump-ingest edge
# function; the edge function sends it as `Authorization: Bearer <WORKER_SECRET>`.
WORKER_SECRET=<random 32+ char secret — openssl rand -base64 32>

# Groq (OpenAI-compatible) — runs whisper-large-v3-turbo.
GROQ_API_KEY=<console.groq.com API key>

# Claude Haiku — summarises the transcript into the Markdown note.
ANTHROPIC_API_KEY=<console.anthropic.com API key — same one the edge functions use>

# Supabase service role — used to download the shared file, update the row, and
# delete the original after transcription (bypasses RLS).
SUPABASE_URL=https://nhyunnnmdcmojvkxrbpl.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<Supabase → Settings → API → service_role key>

# Optional: same key as the Supabase SUPADATA_API_KEY secret (supadata.ai).
# Primary path for YouTube transcript+metadata — this worker only sees a
# YouTube job at all when braindump-ingest's own inline attempt didn't
# produce a transcript, and retries it here (polling long-video async jobs
# to completion, which the edge function can't afford to do). Unset = skip
# straight to the yt-dlp+cookies fallback below.
SUPADATA_API_KEY=<supadata.ai dashboard → API keys — free tier: 100 req/month>

# Optional: path to a Netscape-format cookies.txt (see README's "YouTube
# cookies" section) — last-resort fallback for YouTube videos Supadata
# couldn't transcribe. Works around YouTube's "Sign in to confirm you're not
# a bot" check on cloud-hosted IPs. Defaults to /etc/secrets/youtube-cookies.txt
# (Render's Secret Files mount point); unset/no file present = today's
# unauthenticated behaviour, unchanged.
YT_COOKIES_PATH=/etc/secrets/youtube-cookies.txt

# Optional: same bot token notify-tick already uses (Supabase secret
# TELEGRAM_BOT_TOKEN — same value here). When set, this worker sends one
# Telegram alert the moment YouTube's cookie/bot-check starts failing
# (throttled to once per process lifetime), so a stale cookies.txt gets
# noticed immediately instead of silently degrading every video to a
# metadata-only note until someone happens to check.
TELEGRAM_BOT_TOKEN=<same value as the Supabase TELEGRAM_BOT_TOKEN secret>
